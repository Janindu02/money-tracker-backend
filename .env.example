# Local Docker Postgres
DATABASE_URL="postgresql://finova:finova_secret@localhost:5434/finova_db?schema=public"
# Vercel + Neon (from Neon dashboard → Connection string → Prisma):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
JWT_SECRET="change-me-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="change-me-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
# Comma-separated allowed browser origins (CORS + OAuth redirects)
FRONTEND_URL="http://localhost:3000"
# Production example (Netlify + local dev):
# FRONTEND_URL="https://finovam.netlify.app,http://localhost:3000"
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"
# Vercel production:
# GOOGLE_CALLBACK_URL="https://money-tracker-backend-delta.vercel.app/api/v1/auth/google/callback"
COOKIE_SECURE=false
# Cross-origin frontend (Netlify) + API (Vercel):
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none
COOKIE_DOMAIN=
MAX_SESSIONS_PER_USER=10
SESSION_SECRET=
THROTTLE_TTL=60
THROTTLE_LIMIT=100
